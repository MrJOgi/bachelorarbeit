% @online is used for websites and digital resources that don't fit traditional categories.
% Mandatory fields: author OR editor, title, year/date, url
@online{db_engines,
    author       = {{Red Gate Software Ltd}},
    title        = {DB-Engines Ranking},
    organization = {Db-engines.com},
    year         = {2026},
    url          = {https://db-engines.com},
    urldate      = {2026-03-10}
}

% @inbook is used for a specific chapter or a numbered part of a book.
% Mandatory fields: author OR editor, title, chapter OR pages, publisher, year
@inbook{tanenbaum2021networks,
    author    = {Andrew S. Tanenbaum and David J. Wetherall},
    title     = {The Data Link Layer},
    booktitle = {Computer Networks},
    edition   = {6},
    publisher = {Pearson},
    year      = {2021},
    chapter   = {3},
    pages     = {185--240},
    address   = {Boston, MA},
    isbn      = {978-0137523214}
}

% @techreport is used for reports, white papers, or standards issued by institutions.
% Mandatory fields: author, title, institution, year
@techreport{rfc4880,
    author       = {Hal Finney and Lutz Donnerhacke and Jon Callas and Rodney L. Thayer and Daphne Shaw},
    title        = {{OpenPGP Message Format}},
    institution  = {Internet Engineering Task Force (IETF)},
    year         = {2007},
    month        = nov,
    number       = {4880},
    series       = {Request for Comments},
    publisher    = {RFC Editor},
    howpublished = {RFC 4880},
    pagetotal    = {90},
    doi          = {10.17487/RFC4880},
    url          = {https://www.rfc-editor.org}
}

